<?xml version="1.0" encoding="UTF-8"?>
<architecture name="DX11 Real-Time Rendering Engine">

  <!-- ============================================================ -->
  <!--  RENDERING PIPELINE (per-frame execution order)              -->
  <!-- ============================================================ -->
  <pipeline name="FrameRenderingPipeline">
    <stage order="1" name="FrameTick">
      <step>GameTimer.Tick() -- high-resolution delta time</step>
      <step>CalculateFrameStats() -- FPS counter</step>
      <step>UpdateScene() -- input handling, camera movement</step>
      <step>DrawScene() -- full render pass</step>
    </stage>

    <stage order="2" name="DrawScene">
      <step>ClearRenderTargetView (color buffer)</step>
      <step>ClearDepthStencilView (depth buffer)</step>
      <step>Update camera matrices (View, Projection)</step>
      <step>For each renderable object: bind shader -> send uniforms -> draw</step>
      <step>SwapChain.Present() -- flip back buffer</step>
    </stage>

    <stage order="3" name="PerObjectDraw">
      <step>Shader.SetToContext() -- bind VS, PS, InputLayout</step>
      <step>Shader.SendCamMatrices() -- UpdateSubresource cb0</step>
      <step>Shader.SendLightParameters() -- UpdateSubresource cb1</step>
      <step>Shader.SendWorldAndMaterial() -- UpdateSubresource cb2</step>
      <step>Texture.SetToContext() -- PSSetShaderResources</step>
      <step>Model.SetToContext() -- IASetVertexBuffers, IASetIndexBuffer</step>
      <step>Model.DrawIndexed() -- GPU draw call</step>
    </stage>
  </pipeline>

  <!-- ============================================================ -->
  <!--  CLASS HIERARCHY                                             -->
  <!-- ============================================================ -->
  <module name="ShaderSystem">
    <class name="ShaderBase" type="abstract" file="ShaderBase.cpp/h">
      <responsibility>HLSL compilation, vertex/pixel shader creation, input layout, context binding</responsibility>
      <gpu_resources>
        <resource>ID3D11VertexShader</resource>
        <resource>ID3D11PixelShader</resource>
        <resource>ID3D11InputLayout</resource>
        <resource>ID3DBlob (VS/PS compiled bytecode)</resource>
      </gpu_resources>

      <subclass name="ShaderColor" file="ShaderColor.cpp/h">
        <input_layout>POSITION (R32G32B32A32_FLOAT)</input_layout>
        <constant_buffers>
          <buffer register="cb0" struct="CamMatrices">View, Projection</buffer>
          <buffer register="cb1" struct="Data_WorldColor">World, Color</buffer>
        </constant_buffers>
      </subclass>

      <subclass name="ShaderColorLight" file="ShaderColorLight.cpp/h">
        <input_layout>POSITION (R32G32B32A32_FLOAT), NORMAL (R32G32B32A32_FLOAT)</input_layout>
        <constant_buffers>
          <buffer register="cb0" struct="CamMatrices">View, Projection</buffer>
          <buffer register="cb1" struct="Data_LightParams">DirectionalLight, PointLight[3], SpotLight[3], EyePosWorld</buffer>
          <buffer register="cb2" struct="Data_WorldAndMaterial">World, WorldInverse, Material(Amb/Dif/Spec)</buffer>
          <buffer register="cb3" struct="Fog">FogStart, FogRange, FogColor</buffer>
        </constant_buffers>
        <features>
          <feature>Phong illumination (Ambient + Diffuse + Specular)</feature>
          <feature>Directional light (direction, ADS)</feature>
          <feature>Point lights x3 (position, range, attenuation, ADS)</feature>
          <feature>Spot lights x3 (position, direction, range, spotExp, attenuation, ADS)</feature>
          <feature>Distance-based fog blending</feature>
        </features>
      </subclass>

      <subclass name="ShaderTexture" file="ShaderTexture.cpp/h">
        <input_layout>POSITION (R32G32B32A32_FLOAT), TEXCOORD (R32G32_FLOAT)</input_layout>
        <constant_buffers>
          <buffer register="cb0" struct="CamMatrices">View, Projection</buffer>
          <buffer register="cb1" struct="Data_WorldTex">World</buffer>
        </constant_buffers>
        <gpu_resources>
          <resource>ID3D11ShaderResourceView (texture)</resource>
          <resource>ID3D11SamplerState</resource>
        </gpu_resources>

        <subclass name="ShaderTextureLight" file="ShaderTextureLight.cpp/h">
          <input_layout>POSITION (R32G32B32A32_FLOAT), TEXCOORD (R32G32_FLOAT), NORMAL (R32G32B32A32_FLOAT)</input_layout>
          <constant_buffers>
            <buffer register="cb0" struct="CamMatrices">View, Projection</buffer>
            <buffer register="cb1" struct="Data_LightParams">DirectionalLight, PointLight[3], SpotLight[3], EyePosWorld</buffer>
            <buffer register="cb2" struct="Data_WorldAndMaterial">World, WorldInverse, Material</buffer>
            <buffer register="cb3" struct="Fog">FogStart, FogRange, FogColor</buffer>
          </constant_buffers>
        </subclass>
      </subclass>
    </class>
  </module>

  <module name="RenderableObjects">
    <class name="GraphicObject_Base" type="abstract" file="GraphicObject_Base.cpp/h">
      <responsibility>Abstract rendering interface, model binding</responsibility>

      <subclass name="GraphicObject_Color" file="GraphicObject_Color.cpp/h">
        <references>ShaderColor, Model</references>
        <data>Color array (per mesh)</data>
        <render_flow>For each mesh: SendWorldColor -> RenderMesh</render_flow>
      </subclass>

      <subclass name="GraphicObject_ColorLighting" file="GraphicObject_ColorLighting.cpp/h">
        <references>ShaderColorLight, Model</references>
        <data>Material (Ambient, Diffuse, Specular), World matrix</data>
        <render_flow>SendWorldAndMaterial -> Render all meshes</render_flow>
      </subclass>

      <subclass name="GraphicObject_TextureLight" file="GraphicObject_TextureLight.cpp/h">
        <references>ShaderTextureLight, Model or TerrainModel, Texture</references>
        <data>Material, World matrix, Texture pointer</data>
        <render_flow>SetTexture -> SendWorldAndMaterial -> Render (supports Model and TerrainModel)</render_flow>
      </subclass>
    </class>
  </module>

  <module name="GeometryAndMeshes">
    <class name="Model" file="Model.cpp/h">
      <responsibility>GPU mesh storage, vertex/index buffer management, file loading, procedural generation</responsibility>
      <vertex_format name="StandardVertex">
        <field>Vect Pos (position)</field>
        <field>float u, v (texture coordinates)</field>
        <field>Vect normal</field>
        <field>Vect Color</field>
        <field>int meshNum (mesh separation ID)</field>
      </vertex_format>
      <gpu_resources>
        <resource>ID3D11Buffer (vertex buffer)</resource>
        <resource>ID3D11Buffer (index buffer)</resource>
      </gpu_resources>
      <construction_modes>
        <mode>From arrays (StandardVertex[], TriangleByIndex[])</mode>
        <mode>From file (.azul format via AzulFileHdr)</mode>
        <mode>From PreMadeModels enum (UnitBox, UnitSphere, UnitPyramid, etc.)</mode>
      </construction_modes>
      <draw_calls>
        <call>Render() -- DrawIndexed(numTris*3, 0, 0)</call>
        <call>RenderMesh(meshnum) -- DrawIndexed with MeshSeparator offsets</call>
      </draw_calls>
    </class>

    <class name="MeshSeparator" file="MeshSeparator.cpp/h">
      <responsibility>Reorder triangle indices by mesh ID for efficient batched DrawIndexed calls</responsibility>
      <algorithm>
        <step>Sort triangles into buckets by meshNum using std::map</step>
        <step>Rebuild index array contiguously per mesh</step>
        <step>Store (offset, triCount) per mesh for DrawIndexed</step>
      </algorithm>
    </class>

    <class name="ModelTools" file="ModelTools.cpp/h" type="static">
      <responsibility>Procedural geometry generation</responsibility>
      <generators>
        <generator>CreateUnitBox</generator>
        <generator>CreateUnitBoxRepTexture</generator>
        <generator>CreateUnitBoxSixFacesTexture</generator>
        <generator>CreateUnitPyramid</generator>
        <generator>CreateUnitPyramidRepTexture</generator>
        <generator>CreateUnitSphere (configurable slices)</generator>
      </generators>
    </class>

    <class name="TerrainModel" file="TerrainModel.cpp/h">
      <responsibility>Heightmap-based terrain mesh generation with smooth normals</responsibility>
      <algorithm>
        <step>Load TGA heightmap via DirectXTex</step>
        <step>Sample pixel brightness -> vertex Y height</step>
        <step>Generate NxN vertex grid with UV tiling</step>
        <step>Build triangle index list (2 tris per quad)</step>
        <step>Compute per-vertex normals by averaging 6 adjacent face normals (cross products)</step>
        <step>Upload to GPU via Model constructor</step>
      </algorithm>
      <parameters>heightmapFile, length, maxHeight, yTranslation, RepeatU, RepeatV</parameters>
    </class>

    <class name="SkyBox" file="SkyBox.cpp/h">
      <responsibility>6-face environment cube, always rendered at camera position</responsibility>
      <technique>Cross-texture UV mapping with epsilon offsets to prevent seam artifacts</technique>
      <geometry>24 vertices (4 per face), 12 triangles (2 per face)</geometry>
    </class>

    <class name="FlatPlane" file="FlatPlane.cpp/h">
      <responsibility>Simple flat plane primitive</responsibility>
    </class>
  </module>

  <module name="Camera">
    <class name="Camera" file="Camera.cpp/h">
      <responsibility>Perspective projection, view matrix, first-person movement</responsibility>
      <matrices>
        <matrix name="Projection">
          <technique>Manual perspective matrix: d = 1/tan(fovy/2), aspect ratio correction</technique>
          <technique>OpenGL NDC [-1,1] to DirectX NDC [0,1] conversion via translate+scale</technique>
        </matrix>
        <matrix name="View">
          <technique>Right-hand basis vectors (vRight, vUp, vDir)</technique>
          <technique>Translation via dot products: R^T * (-Pos)</technique>
        </matrix>
      </matrices>
      <orientation>
        <technique>Gram-Schmidt orthogonalization from look-at point</technique>
        <technique>vDir flipped for right-hand convention</technique>
      </orientation>
      <movement>
        <method>TranslateFwdBack (along -vDir)</method>
        <method>TranslateLeftRight (along vRight)</method>
        <method>TiltUpDown (rotation about vRight axis)</method>
        <method>TurnLeftRight (rotation about Y axis)</method>
      </movement>
    </class>
  </module>

  <module name="Resources">
    <class name="Texture" file="Texture.cpp/h">
      <responsibility>Image loading, GPU texture creation, sampler state, mipmap generation</responsibility>
      <formats>TGA (LoadFromTGAFile), DDS (LoadFromDDSFile)</formats>
      <gpu_resources>
        <resource>ID3D11ShaderResourceView</resource>
        <resource>ID3D11SamplerState (trilinear filtering, 4x anisotropic)</resource>
      </gpu_resources>
      <features>
        <feature>Automatic mipmap generation (DirectX::GenerateMipMaps)</feature>
        <feature>Configurable filter modes (POINT, LINEAR, etc.)</feature>
      </features>
    </class>

    <class name="AzulFileHdr" file="AzulFileHdr.h" type="struct">
      <responsibility>Custom 3D model binary file format</responsibility>
      <fields>objectName, numVerts, numTriangles, vertBufferOffset, triangleListBufferOffset</fields>
      <bounding_volumes>Sphere (center, radius), AABB (min, max)</bounding_volumes>
    </class>
  </module>

  <module name="Application">
    <class name="DXApp" file="DXApp.cpp/h">
      <responsibility>Main application: D3D11 initialization, game loop, scene orchestration</responsibility>
      <initialization>
        <step>InitDirect3D() -- device, swap chain, rasterizer, depth-stencil, viewport</step>
        <step>InitDemo() -- shaders, models, textures, lights, scene objects</step>
      </initialization>
      <game_loop>
        <step>GameTimer.Tick()</step>
        <step>UpdateScene() -- WASD/arrow input, camera update</step>
        <step>DrawScene() -- clear, bind, render all objects, present</step>
      </game_loop>
      <debug>
        <feature>ID3D11Debug.ReportLiveDeviceObjects() for leak detection</feature>
        <feature>D3D11_CREATE_DEVICE_DEBUG flag</feature>
      </debug>
    </class>

    <class name="GameTimer" file="GameTimer.cpp/h">
      <responsibility>High-resolution frame timing via QueryPerformanceCounter</responsibility>
      <features>DeltaTime, TotalTime, Pause/Resume</features>
    </class>
  </module>

  <!-- ============================================================ -->
  <!--  GPU RESOURCE OWNERSHIP MAP                                  -->
  <!-- ============================================================ -->
  <gpu_resources>
    <owner class="DXApp">
      <resource type="ID3D11Device">md3dDevice</resource>
      <resource type="ID3D11DeviceContext">md3dImmediateContext</resource>
      <resource type="IDXGISwapChain">mSwapChain</resource>
      <resource type="ID3D11RenderTargetView">mRenderTargetView</resource>
      <resource type="ID3D11DepthStencilView">mpDepthStencilView</resource>
    </owner>
    <owner class="ShaderBase">
      <resource type="ID3D11VertexShader">mpVertexShader</resource>
      <resource type="ID3D11PixelShader">mpPixelShader</resource>
      <resource type="ID3D11InputLayout">mpVertexLayout</resource>
      <resource type="ID3DBlob">pVSBlob, pPSBlob</resource>
    </owner>
    <owner class="ShaderColorLight (and variants)">
      <resource type="ID3D11Buffer">mpBufferCamMatrices (cb0)</resource>
      <resource type="ID3D11Buffer">mpBufferLightParams (cb1)</resource>
      <resource type="ID3D11Buffer">mpBuffWordAndMaterial (cb2)</resource>
      <resource type="ID3D11Buffer">mpBufferFog (cb3)</resource>
    </owner>
    <owner class="Model">
      <resource type="ID3D11Buffer">mpVertexBuffer</resource>
      <resource type="ID3D11Buffer">mpIndexBuffer</resource>
    </owner>
    <owner class="Texture">
      <resource type="ID3D11ShaderResourceView">texture resource view</resource>
      <resource type="ID3D11SamplerState">sampler state</resource>
    </owner>
  </gpu_resources>

  <!-- ============================================================ -->
  <!--  MEMORY ALIGNMENT                                            -->
  <!-- ============================================================ -->
  <memory_management>
    <base_class name="Align16">
      <purpose>16-byte alignment for SIMD (SSE) compatibility</purpose>
      <inheritors>ShaderBase, Model::StandardVertex, TerrainModel, SkyBox, GraphicObject_Base, Camera</inheritors>
    </base_class>
    <com_cleanup macro="ReleaseAndDeleteCOMobject">
      <usage>All ID3D11* and IDXGI* resources released via this macro in destructors</usage>
    </com_cleanup>
  </memory_management>

</architecture>
